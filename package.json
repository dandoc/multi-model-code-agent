{
  "name": "multi-model-code-agent",
  "version": "0.1.0",
  "private": true,
  "description": "A beginner-friendly multi-model coding agent CLI with Ollama and OpenAI-compatible backends.",
  "type": "module",
  "bin": {
    "mm-agent": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "smoke": "npm run smoke:core && npm run smoke:paths && npm run smoke:sessions",
    "smoke:core": "tsx src/smoke.ts",
    "smoke:failures": "tsx src/writePatchFailureSmoke.ts",
    "smoke:batch": "tsx src/writePatchBatchSmoke.ts",
    "smoke:paths": "tsx src/pathSecuritySmoke.ts",
    "smoke:sessions": "tsx src/sessionSmoke.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
